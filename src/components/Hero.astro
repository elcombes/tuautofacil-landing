---
// src/components/Hero.astro

// Declaramos la lista de autos de forma limpia y nativa en el servidor (Astro Frontmatter)
const cars = [
  { name: 'Peugeot 208', img: '/images/cars/peugeot.png', badge: 'Peugeot' },
  { name: 'Fiat Cronos', img: '/images/cars/fiat.png', badge: 'Fiat' },
  { name: 'Ford Ranger', img: '/images/cars/ford.png', badge: 'Ford' }
];
---
<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden py-8 md:py-16 px-6 lg:px-8">
  
  <!-- Efecto de Brillo de fondo (Glow) adaptado al Coral de tu logo -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[600px] h-[350px] md:h-[600px] bg-brand-accent/5 rounded-full blur-[100px] md:blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center relative z-10 w-full">
    
    <!-- Lado Izquierdo: Textos, propuesta de valor y llamados a la acción -->
    <div class="space-y-6 md:space-y-8 text-center lg:text-left order-2 lg:order-1 animate-fade-in-up">
      
      <!-- Badge indicador con ping de animación Coral -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full text-sm backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
        </span>
        <span class="text-gray-300 font-semibold tracking-wide">Simulador Oficial</span>
      </div>
      
      <!-- Título de alto impacto -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight">
        Cotizá tu 0km<br>de forma <br class="hidden md:inline"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">segura y directa.</span>
      </h1>
      
      <!-- Subtítulo / Propuesta de valor -->
      <p class="text-base sm:text-lg text-gray-400 max-w-lg mx-auto lg:mx-0 leading-relaxed font-light">
        Encontrá el auto que se ajuste a tu bolsillo en solo 4 pasos. Te conectamos directamente con asesores oficiales de marcas líderes.
      </p>

      <!-- Botones de Acción -->
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
        <a 
          href="https://solicitud.tuautofacil.com.ar" 
          target="_blank" 
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-8 py-4 bg-brand-accent hover:bg-red-400 text-brand-white font-extrabold rounded-xl text-center tracking-wide transition-all duration-300 hover:shadow-[0_0_35px_rgba(255,85,91,0.4)] transform hover:-translate-y-0.5"
        >
          Simular mi 0KM
        </a>
        <a 
          href="#brands" 
          class="w-full sm:w-auto px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold rounded-xl text-center transition-all duration-300 transform hover:-translate-y-0.5"
        >
          Más info
        </a>
      </div>
    </div>

    <!-- Lado Derecho: Showcase de Autos Interactivo con Autoplay (Astro + Alpine.js) -->
    <div 
      class="relative flex flex-col items-center justify-center order-1 lg:order-2 animate-fade-in-right py-2 lg:py-6 w-full overflow-hidden"
      x-data="{ 
        activeCar: 0, 
        init() {
          setInterval(() => {
            this.activeCar = (this.activeCar + 1) % 3;
          }, 4000);
        }
      }"
    >
      <!-- Contenedor de la Imagen con alto estable en móvil -->
      <div class="relative w-full h-[160px] sm:h-[200px] md:h-[280px] lg:h-[350px] flex items-center justify-center">
        
        {cars.map((car, index) => (
          <div 
            x-show={`activeCar === ${index}`}
            class="absolute inset-0 flex items-center justify-center"
            x-transition:enter="transition ease-out duration-500"
            x-transition:enter-start="opacity-0 scale-95 translate-x-8"
            x-transition:enter-end="opacity-100 scale-100 translate-x-0"
            x-transition:leave="transition ease-in duration-300 absolute"
            x-transition:leave-start="opacity-100 scale-100 translate-x-0"
            x-transition:leave-end="opacity-0 scale-95 -translate-x-8"
          >
            <img 
              src={car.img} 
              alt={car.name} 
              class="w-full max-w-[280px] sm:max-w-[340px] md:max-w-[600px] lg:max-w-[680px] object-contain animate-float"
            />
          </div>
        ))}

      </div>

      

    </div>

  </div>
</section>

<style>
  /* Animaciones de entrada elegantes mediante CSS nativo para un rendimiento óptimo */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Animación continua de flotación */
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-fade-in-right {
    animation: fadeInRight 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>