---
// src/components/Hero.astro
---
<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden py-16 px-6 lg:px-8">
  
  <!-- Efecto de Brillo de fondo (Glow) para dar profundidad tridimensional -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[600px] h-[350px] md:h-[600px] bg-emerald-500/10 rounded-full blur-[100px] md:blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center relative z-10 w-full">
    
    <!-- Lado Izquierdo: Textos, propuesta de valor y llamados a la acción -->
    <div class="space-y-6 md:space-y-8 text-center lg:text-left order-2 lg:order-1 animate-fade-in-up">
      
      <!-- Badge indicador con ping de animación -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full text-sm backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-gray-300 font-semibold tracking-wide">Simulador Oficial</span>
      </div>
      
      <!-- Título de alto impacto -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight">
        Cotizá tu 0km<br>de forma <br class="hidden md:inline"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">segura y directa.</span>
      </h1>
      
      <!-- Subtítulo / Propuesta de valor -->
      <p class="text-base sm:text-lg text-gray-400 max-w-lg mx-auto lg:mx-0 leading-relaxed font-light">
        Encontrá el auto que se ajuste a tu bolsillo en solo 4 pasos. Te conectamos directamente con asesores oficiales de marcas líderes.
      </p>

      <!-- Botones de Acción (Unificados en la misma paleta de tu simulador) -->
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
        <a 
          href="https://solicitud.tuautofacil.com.ar" 
          target="_blank" 
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-8 py-4 bg-emerald-500 hover:bg-emerald-400 text-black font-extrabold rounded-xl text-center tracking-wide transition-all duration-300 hover:shadow-[0_0_35px_rgba(16,185,129,0.3)] transform hover:-translate-y-0.5"
        >
          Simular mi 0KM
        </a>
        <a 
          href="https://wa.me/tu_numero_aqui" 
          target="_blank" 
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold rounded-xl text-center transition-all duration-300 transform hover:-translate-y-0.5"
        >
          Consultar por WhatsApp
        </a>
      </div>
    </div>

    <!-- Lado Derecho: Imagen del auto principal con sombra de contacto en el suelo -->
    <div class="relative flex flex-col items-center justify-center order-1 lg:order-2 animate-fade-in-right py-6">
      <!-- 
        Nota: He dejado un auto de muestra de Peugeot que se adapta muy bien al fondo oscuro. 
        Luego podrás cambiar este archivo por la imagen PNG transparente del auto que prefieras.
      -->
      <img 
        src="/images/hero-car.png" 
        alt="Simulador 0km Oficial" 
        class="relative z-10 w-full max-w-[420px] md:max-w-[500px] object-contain drop-shadow-[0_15px_30px_rgba(0,0,0,0.7)]"
      />
    </div>

  </div>
</section>

<style>
  /* Animaciones de entrada elegantes mediante CSS nativo para un rendimiento óptimo */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-fade-in-right {
    animation: fadeInRight 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>