---
// src/components/CallToAction.astro
---
<section class="py-20 bg-brand-dark px-6 lg:px-8 relative overflow-hidden">
  
  <!-- Tarjeta contenedora flotante -->
  <div class="max-w-5xl mx-auto relative rounded-3xl overflow-hidden border border-white/5 bg-gradient-to-br from-brand-navy to-brand-dark px-8 py-16 md:py-20 text-center shadow-2xl">
    
    <!-- Brillo radial de fondo -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[450px] h-[300px] md:h-[450px] bg-brand-accent/15 rounded-full blur-[80px] md:blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-2xl mx-auto space-y-8">
      
      <!-- 
        NUEVO ELEMENTO DE MICRO-UX: Indicador de Estado Activo.
        Genera confianza e inmediatez en el usuario.
      -->
      <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 px-4 py-1.5 rounded-full text-xs font-semibold text-emerald-400 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Asesores Oficiales: Online ahora (Atención inmediata)
      </div>

      <!-- Título de acción definitivo -->
      <h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight">
        Tu 0km está más cerca <br class="hidden sm:inline" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-accent via-red-400 to-white">de lo que pensás.</span>
      </h2>

      <p class="text-gray-300 text-sm md:text-base font-light leading-relaxed">
        Completar la simulación te tomará menos de 2 minutos y es 100% gratuito. Ingresá ahora para calcular tu cuota ideal y recibir propuestas de concesionarios oficiales.
      </p>

      <!-- Botón Coral con la clase de animación 'animate-ripple' -->
      <div class="pt-4 flex flex-col items-center justify-center gap-4">
        <a 
          href="https://solicitud.tuautofacil.com.ar" 
          target="_blank" 
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-12 py-5 bg-brand-accent hover:bg-red-400 text-brand-white font-black rounded-2xl tracking-wider text-base transition-all duration-300 transform hover:scale-[1.02] animate-ripple"
        >
          Simular Ahora
        </a>
      </div>

      <!-- Garantías rápidas -->
      <div class="pt-8 border-t border-white/5 flex flex-wrap justify-center items-center gap-x-8 gap-y-4 text-xs font-semibold text-gray-400">
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Sin compromiso de compra
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Seguridad y protección de datos
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Canales 100% oficiales
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Estilo CSS nativo para el efecto de pulso de luz (Onda expansiva) -->
<style>
  @keyframes ripple {
    0% {
      /* Sombra inicial pegada al botón */
      box-shadow: 0 0 0 0 rgba(255, 85, 91, 0.4);
    }
    70% {
      /* La sombra se expande 15px hacia afuera y se vuelve casi transparente */
      box-shadow: 0 0 0 15px rgba(255, 85, 91, 0);
    }
    100% {
      /* Se desvanece por completo antes de reiniciar */
      box-shadow: 0 0 0 0 rgba(255, 85, 91, 0);
    }
  }

  .animate-ripple {
    /* Ciclo infinito de 2.5 segundos */
    animation: ripple 2.5s cubic-bezier(0.25, 0, 0, 1) infinite;
  }
</style>