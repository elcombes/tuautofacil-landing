---
// src/components/Brands.astro
---
<section id="brands" class="py-16 bg-brand-dark border-y border-white/5 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <!-- Micro-texto persuasivo -->
    <p class="text-center text-xs md:text-sm font-semibold tracking-widest text-gray-400 uppercase mb-10">
      Alianzas exclusivas con concesionarias y redes oficiales
    </p>

    <!-- Contenedor centrado plano y sin escalados -->
    <div class="flex flex-col md:flex-row justify-center items-center gap-10 md:gap-24 max-w-4xl mx-auto">
      
      <!-- Marca 1: Fiat -->
      <div class="flex justify-center items-center h-16 w-32 md:w-40">
        <img 
          src="/images/brands/fiat.png" 
          alt="Fiat" 
          class="h-10 md:h-12 w-auto object-contain opacity-40 hover:opacity-100 transition-opacity duration-300" 
        />
      </div>

      <!-- Marca 2: Peugeot -->
      <div class="flex justify-center items-center h-16 w-32 md:w-40">
        <img 
          src="/images/brands/peugeot.png" 
          alt="Peugeot" 
          class="h-10 md:h-12 w-auto object-contain opacity-40 hover:opacity-100 transition-opacity duration-300" 
        />
      </div>

      <!-- Marca 3: Ford -->
      <div class="flex justify-center items-center h-16 w-32 md:w-40">
        <img 
          src="/images/brands/ford.png" 
          alt="Ford" 
          class="h-10 md:h-12 w-auto object-contain opacity-40 hover:opacity-100 transition-opacity duration-300" 
        />
      </div>

    </div>

  </div>
</section>